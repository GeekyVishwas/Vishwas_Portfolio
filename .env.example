# Telegram Contact Form Information
# Steps to obtain:
# 1. Search for @BotFather in Telegram and send /newbot to create your bot and get the Token.
# 2. Search for @userinfobot in Telegram and click Start to get your numeric Chat ID.
# 3. Paste the values below without quotes.

VITE_TELEGRAM_BOT_TOKEN=your_bot_token_here
VITE_TELEGRAM_CHAT_ID=your_chat_id_here

# Telegram Analytics Bot Information (Optional but recommended)
# Create a second bot via @BotFather to separate contact forms from visitor logs.
VITE_ANALYTICS_BOT_TOKEN=your_analytics_bot_token_here
VITE_ANALYTICS_CHAT_ID=your_same_chat_id_here
